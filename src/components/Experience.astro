---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { ExperienceProps } from "@types";

interface Props {
  title: string;
  href: string;
  variant?: "default" | "work";
  experience: ExperienceProps[];
}

const { title, href, variant = "default", experience } = Astro.props;
---

<Section text={title} href={href}>
  {
    experience.map(
      ({ company, logo, position, startDate, endDate, highlights, details, summary }) => (
      <div class="mb-10">
        {variant === "work" ? (
          <>
            <div class="mb-5 flex items-start gap-4">
              {logo && (
                <div class="flex h-14 w-20 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-white/70 bg-white px-3 py-2 shadow-[0_10px_30px_rgba(255,255,255,0.08)]">
                  <Image
                    src={logo}
                    alt={`${company} logo`}
                    width="76"
                    height="40"
                  />
                </div>
              )}
              <div class="pt-1">
                <h3 class="font-serif text-3xl font-semibold text-white">
                  {position}
                </h3>
                <p class="mt-1 text-lg font-medium text-white">
                  {company}
                </p>
                <span class="mt-1 block text-sm text-white/70">
                  {startDate} — {endDate}
                </span>
              </div>
            </div>
            {details && details.length > 0 && (
              <div class="mb-6 overflow-hidden rounded-3xl border border-white/10 bg-linear-to-br from-[#1c2330] to-[#151b25] px-5 py-5 shadow-[0_20px_60px_rgba(0,0,0,0.25)]">
                <div class="space-y-4">
                  {details.map(({ label, value }) => (
                    <div class="grid gap-2 md:grid-cols-[140px_1fr] md:gap-4">
                      <span class="inline-flex h-fit w-fit rounded-full bg-primary/12 px-3 py-1 text-xs font-semibold tracking-wide text-primary uppercase">
                        {label}
                      </span>
                      <p class="text-base leading-7 text-white/80">{value}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </>
        ) : (
          <>
            <div class="mb-4 flex items-center gap-4">
              {logo && (
                <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-white/70 bg-white p-2.5 shadow-[0_10px_30px_rgba(255,255,255,0.08)]">
                  <Image src={logo} alt={`${company} logo`} width="56" height="56" />
                </div>
              )}
              <h3 class="font-serif text-2xl font-semibold text-white">{company}</h3>
            </div>
            <div class="flex flex-col items-start pb-5">
              <h4 class="mb-0.5 font-serif text-2xl font-medium text-primary">
                {position}
              </h4>
              <span class="pb-0.5 text-sm text-white/70">
                {startDate} — {endDate}
              </span>
            </div>
          </>
        )}
        {highlights && highlights.length > 0 && (
          <div class="mb-5 flex flex-wrap gap-2">
            {highlights.map((item) => (
              <span class="rounded-full border border-primary/35 bg-primary/12 px-3 py-1 text-xs font-medium tracking-wide text-primary">
                {item}
              </span>
            ))}
          </div>
        )}
        {Array.isArray(summary) && (
          <ul class="list-none">
            {summary.map((log) => (
              <li class="relative mb-3 pl-8 text-base text-neutral before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
                {log}
              </li>
            ))}
          </ul>
        )}
        {!Array.isArray(summary) && summary && (
          <p class="text-base text-neutral">{summary}</p>
        )}
      </div>
    ))
  }
</Section>
